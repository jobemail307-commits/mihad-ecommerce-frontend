---
import HeroCarousel from "@/components/Hero/HeroCarousel";
import { getImage } from "astro:assets";
import type { GetImageResult } from "astro";

import BlueRobe from "@/assets/heroImages/blueRobe.jpeg";
import DesertRed from "@/assets/heroImages/desertRed.jpeg";
import DesertWhite from "@/assets/heroImages/desertWhite.jpeg";
import InteriorOlivey from "@/assets/heroImages/interiorOlivey.jpeg";
import SandBricksRed from "@/assets/heroImages/sandBricksRed.jpeg";
import Sunshine from "@/assets/heroImages/sunshine.jpeg";

interface Panel {
  image: {
    src: ImageMetadata;
    alt: string;
  };
  link: {
    href: string;
    name: string;
  };
}

const panels: Panel[] = [
  {
    image: {
      src: BlueRobe,
      alt: "Blue robe",
    },
    link: {
      name: "Stuff",
      href: "/cart",
    },
  },
  {
    image: {
      src: DesertRed,
      alt: "Red dress",
    },
    link: {
      name: "Stuff",
      href: "/cart",
    },
  },
  {
    image: {
      src: DesertWhite,
      alt: "White dress",
    },
    link: {
      name: "Stuff",
      href: "/cart",
    },
  },
  {
    image: {
      src: InteriorOlivey,
      alt: "Olive-colored dress",
    },
    link: {
      name: "Stuff",
      href: "/cart",
    },
  },
  {
    image: {
      src: SandBricksRed,
      alt: "Red dress",
    },
    link: {
      name: "Stuff",
      href: "/cart",
    },
  },
  {
    image: {
      src: Sunshine,
      alt: "Pink dress",
    },
    link: {
      name: "Stuff",
      href: "/cart",
    },
  },
];

const optimizedPanels: {
  image: {
    imageResult: GetImageResult;
    alt: string;
  };
  link: { name: string; href: string };
}[] = [];

panels.forEach(async ({ image, link }) => {
  const result = {
    link,
    image: {
      alt: image.alt,
      imageResult: await getImage({ src: image.src, priority: true }),
    },
  };
  optimizedPanels.push(result);
});
---

<HeroCarousel client:load panels={optimizedPanels} />

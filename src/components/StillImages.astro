---
import StillImageSection from "@/components/StillImages/StillImageSection.astro";

import Black from "@/assets/stillImages/black.jpg";
import BlueSuit from "@/assets/stillImages/blueSuit.jpg";
import BrownSuit from "@/assets/stillImages/brownSuit.jpg";
import CrimsonSuit from "@/assets/stillImages/crimsonSuit.jpg";
import Red from "@/assets/stillImages/red.jpeg";
import YellowSuit from "@/assets/stillImages/yellowSuit.jpeg";

const sections = [
  {
    image: {
      src: Red,
      alt: "Girl suit, dark red",
    },
    collection: {
      name: "Shopping cart",
      href: "/cart",
    },
  },
  {
    image: {
      src: Black,
      alt: "Girl suit, black",
    },
    collection: {
      name: "Shopping cart",
      href: "/cart",
    },
  },
  {
    image: {
      src: BlueSuit,
      alt: "Girl suit, dark blue",
    },
    collection: {
      name: "Shopping cart",
      href: "/cart",
    },
  },
  {
    image: {
      src: CrimsonSuit,
      alt: "Girl suit, crimson red",
    },
    collection: {
      name: "Shopping cart",
      href: "/cart",
    },
  },
  {
    image: {
      src: BrownSuit,
      alt: "Girl suit, brown",
    },
    collection: {
      name: "Shopping cart",
      href: "/cart",
    },
  },
  {
    image: {
      src: YellowSuit,
      alt: "Girl suit, yellow",
    },
    collection: {
      name: "Shopping cart",
      href: "/cart",
    },
  },
];
---

{
  sections.map(({ collection, image }) => (
    <StillImageSection collection={collection} image={image} />
  ))
}
